# Provenance — environment configuration template.
# Copy to .env and fill in. .env is git-ignored; never commit real values.

# ---- LLM routing (A2) ----
# Per-task: LLM_<TASK>="<provider>:<model>" (provider = anthropic | local | vllm | ollama).
# Unset / empty / "heuristic" => that task runs the offline heuristic.
#
# Tier aliases: set LLM_TIER_HIGH / LLM_TIER_LOW once, then point each task at "high" or
# "low" — swapping the underlying model is then a one-line change. A task may still name a
# provider:model directly (e.g. keep EVAL_JUDGE on Claude as the trusted ruler).
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8                 # default Claude model when a spec omits one
LLM_TIER_HIGH=local:qwen3.6:27b           # capable model: synthesis + critique
LLM_TIER_LOW=local:qwen3.5:9b             # fast model: detection, planning, bulk extraction
LLM_EXTRACTION=low
LLM_DETECTION=low
LLM_PLANNER=low
LLM_SYNTHESIZER=high
LLM_CRITIC=high
LLM_EVAL_JUDGE=anthropic:claude-opus-4-8  # judge ≠ generator; keep on Claude while testing local
# Local open-source models (Ollama / vLLM / SGLang, OpenAI-compatible API):
LLM_LOCAL_BASE_URL=http://ollama:11434/v1  # compose Ollama; vLLM on the Spark: http://spark:8000/v1
# LLM_LOCAL_API_KEY=                       # if your local server requires one

# ---- Embeddings & reranker (local, air-gap-friendly) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Recorded per index and enforced at query time (R66).

# ---- Catalog (Postgres) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=provenance
POSTGRES_USER=provenance
POSTGRES_PASSWORD=change-me

# ---- Vector store (select the active adapter behind VectorStorePort) ----
# one of: faiss | qdrant | pgvector
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
FAISS_INDEX_DIR=/data/faiss

# ---- Knowledge graph (Kuzu, embedded in the Graph service) ----
KUZU_DB_PATH=/data/kuzu

# ---- Message queue (NATS JetStream) ----
NATS_URL=nats://nats:4222

# ---- Parse / OCR ----
# auto = per-document gate: scanned/table-heavy → Docling (deep, GPU-capable), clean prose
#        → pdfplumber+RapidOCR (fast). docling = always deep; pdfplumber = always light.
PARSE_ENGINE=auto
PARSE_USE_GPU=true              # Docling layout/table/OCR models on GPU (Spark); CPU if false

# ---- Observability (OpenTelemetry) ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=provenance

# ---- Gateway ----
GATEWAY_PORT=8000
MAX_ITERATIONS=3          # hard bound on the Planner→Critic revision loop (R32)
MAX_UPLOAD_MB=50          # upload size cap (R67)
